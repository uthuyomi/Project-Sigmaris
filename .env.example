# Project-Sigmaris (monorepo) root env example
#
# Copy `.env.example` -> `.env` at the repository root, then edit values.
#
# Notes:
# - `.env` is ignored by git in this repo (do not commit secrets).
# - `touhou-talk-ui` also supports `touhou-talk-ui/.env.local` (standard Next.js),
#   but `npm run dev` intentionally loads repo-root `.env` first via `touhou-talk-ui/tools/dev.mjs`.

# ------------------------------------------------------------
# [shared] Supabase (public + server aliases)
# ------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-side aliases (used by Python services and some Node server routes)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_SCHEMA=public

# ------------------------------------------------------------
# [gensokyo-persona-core] Backend (FastAPI / Persona OS)
# ------------------------------------------------------------
OPENAI_API_KEY=

# Models
SIGMARIS_PERSONA_MODEL=gpt-5.2
SIGMARIS_EMBEDDING_MODEL=text-embedding-3-small

# Auth / identity
SIGMARIS_DEFAULT_USER_ID=default-user
SIGMARIS_INTERNAL_TOKEN=
SIGMARIS_REQUIRE_AUTH=1
SIGMARIS_CORS_ORIGINS=

# Debug / tracing
SIGMARIS_TRACE=1
SIGMARIS_TRACE_TEXT=0
SIGMARIS_RAISE_LLM_ERRORS=0

# Phase04: attachments / storage
SIGMARIS_STORAGE_BUCKET=sigmaris-attachments
SIGMARIS_UPLOAD_MAX_BYTES=5242880

# Phase04: external I/O cache/audit
SIGMARIS_IO_CACHE_ENABLED=1
SIGMARIS_IO_CACHE_TTL_SEC=3600
SIGMARIS_IO_AUDIT_STORE_EXCERPT_CHARS=2000

# Web fetch (SSRF-guarded)
SIGMARIS_WEB_FETCH_ALLOW_DOMAINS=
SIGMARIS_WEB_FETCH_ALLOW_ALL=0
SIGMARIS_WEB_FETCH_TIMEOUT_SEC=
SIGMARIS_WEB_FETCH_MAX_BYTES=
SIGMARIS_WEB_FETCH_USER_AGENT=
SIGMARIS_WEB_FETCH_ACCEPT_LANGUAGE=

# Web fetch summarization (optional)
SIGMARIS_WEB_FETCH_SUMMARIZE=0
SIGMARIS_WEB_FETCH_SUMMARY_MODEL=
SIGMARIS_WEB_FETCH_SUMMARY_TIMEOUT_SEC=

# Web RAG (optional)
SIGMARIS_WEB_RAG_ENABLED=0
SIGMARIS_WEB_RAG_AUTO=0
SIGMARIS_WEB_RAG_ALLOW_DOMAINS=
SIGMARIS_WEB_RAG_DENY_DOMAINS=
SIGMARIS_WEB_RAG_RECENCY_DAYS=
SIGMARIS_WEB_RAG_CRAWL_CROSS_DOMAIN=0
SIGMARIS_WEB_RAG_SUMMARIZE=0

# External providers (optional)
SERPER_API_KEY=
GITHUB_TOKEN=

# Image/vision (optional; only when enabled)
SIGMARIS_IMAGE_VISION_ENABLED=0
SIGMARIS_IMAGE_VISION_MODEL=
SIGMARIS_IMAGE_VISION_TIMEOUT_SEC=

# ------------------------------------------------------------
# [touhou-talk-ui] UI (Next.js / Electron)
# ------------------------------------------------------------
# Persona core base URL
SIGMARIS_CORE_URL=http://127.0.0.1:8000
NEXT_PUBLIC_SIGMARIS_CORE=http://127.0.0.1:8000

# Site URL for metadata/SEO (optional; Vercel uses VERCEL_URL fallback)
NEXT_PUBLIC_SITE_URL=

# CORS / hardening (server routes)
TOUHOU_ALLOWED_ORIGINS=
TOUHOU_RATE_LIMIT_MS=1200

# Admin/operator controls (server-side only)
SIGMARIS_OPERATOR_KEY=__CHANGE_ME__
SIGMARIS_OPERATOR_USER_IDS=
TOUHOU_ADMIN_USER_IDS=

# Upload / browse features (server routes; optional)
TOUHOU_UPLOAD_ENABLED=0
SIGMARIS_AUTO_BROWSE_ENABLED=0
SIGMARIS_AUTO_BROWSE_MAX_RESULTS=5
SIGMARIS_AUTO_BROWSE_FETCH_TOP=2
SIGMARIS_AUTO_BROWSE_NEWS_DOMAINS=

# Desktop runtime/dev (optional)
TOUHOU_DESKTOP_PORT=3789
TOUHOU_DESKTOP_ENV_PATH=
TOUHOU_DESKTOP_USERDATA_DIR=
TOUHOU_DESKTOP_DEV_PORT=
TOUHOU_DESKTOP_DEV_URL=
TOUHOU_DESKTOP_DEV_NO_ELECTRON=0

# Optional world integration (UI client)
NEXT_PUBLIC_GENSOKYO_WS_URL=
GENSOKYO_WORLD_ENGINE_URL=
GENSOKYO_WORLD_ENGINE_SECRET=

# ------------------------------------------------------------
# [gensokyo-world-engine] (optional)
# ------------------------------------------------------------
GENSOKYO_WORLD_ENGINE_PORT=8010
GENSOKYO_WORLD_ENGINE_SECRET=

# How world-engine calls the persona core (optional)
GENSOKYO_PERSONA_CORE_URL=http://127.0.0.1:8000
GENSOKYO_PERSONA_CORE_INTERNAL_TOKEN=
GENSOKYO_PERSONA_CORE_BEARER_TOKEN=

# Command worker
GENSOKYO_COMMAND_WORKER_ENABLED=1
GENSOKYO_COMMAND_WORKER_POLL_MS=500
GENSOKYO_COMMAND_WORKER_BATCH=20

# Time skip simulation
GENSOKYO_WORLD_SIM_ENABLED=0
GENSOKYO_WORLD_SIM_INTERVAL_SEC=120
GENSOKYO_WORLD_SIM_NPC_MOVE_PROB=
GENSOKYO_WORLD_SIM_ACTIVE_WINDOW_SEC=
GENSOKYO_WORLD_SIM_MAX_LOCATIONS=

# Content
GENSOKYO_CONTENT_ROOT=

# NPC planners/dialogue (optional; see `gensokyo-world-engine/server.py`)
GENSOKYO_NPC_PLANNER_ENABLED=
GENSOKYO_NPC_PLANNER_LLM_PROVIDER=
GENSOKYO_NPC_PLANNER_COOLDOWN_SEC=
GENSOKYO_NPC_PLANNER_MAX_EVENTS=
GENSOKYO_NPC_SHORT_MEMORY_BACKEND=

GENSOKYO_NPC_DIALOGUE_ENABLED=
GENSOKYO_NPC_DIALOGUE_PROBABILITY=
GENSOKYO_NPC_DIALOGUE_MAX_EVENTS=

# Relationship tuning (optional)
GENSOKYO_REL_DELTA_TRUST_SAY=
GENSOKYO_REL_DELTA_FRIENDSHIP_SAY=
GENSOKYO_REL_DELTA_AFFINITY_SAY=

# ------------------------------------------------------------
# [gensokyo-event-gateway] (optional)
# ------------------------------------------------------------
GENSOKYO_EVENT_GATEWAY_HOST=127.0.0.1
GENSOKYO_EVENT_GATEWAY_PORT=8787
GENSOKYO_EVENT_GATEWAY_ALLOW_ANON=1
